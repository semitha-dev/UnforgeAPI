# Server
PORT=8080
APP_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Unkey (API key management & rate limiting)
UNKEY_ROOT_KEY=your-unkey-root-key

# Upstash Redis (caching & priority queue)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Polar (payments)
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
POLAR_MANAGED_INDIE_PRODUCT_ID=
POLAR_MANAGED_PRO_PRODUCT_ID=
POLAR_MANAGED_EXPERT_PRODUCT_ID=
POLAR_MANAGED_PRODUCTION_PRODUCT_ID=

# LLM Providers
GROQ_API_KEY=your-groq-api-key
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Tavily (web search)
TAVILY_API_KEY=your-tavily-api-key

# CORS (frontend origin)
CORS_ORIGIN=http://localhost:5173

# Debug
DEBUG=true
DEBUG_VERBOSE=false
